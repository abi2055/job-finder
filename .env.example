# Optional: raises GitHub API limits for sources that use GitHub.
GITHUB_TOKEN=

# Required for email notifications.
RESEND_API_KEY=
RESEND_TO_EMAIL=

# Resend requires this sender to be allowed by your account/domain.
# For early testing, Resend's examples use: Job Notifier <onboarding@resend.dev>
RESEND_FROM_EMAIL=Job Notifier <onboarding@resend.dev>

